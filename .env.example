# Copy to .env and fill in. NEVER commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Model. Skill default is Opus 4.8. Sonnet 4.6 is a cheaper swap for the high-volume
# screenshot loop and uses the SAME computer-use beta + tool version.
CU_MODEL=claude-opus-4-8

# Safety mode:  dryrun | confirm | auto
#   dryrun  = print the planned action, execute NOTHING
#   confirm = ask y/N before every action (use this for first runs)
#   auto    = execute without asking (only once you trust it)
CU_MODE=confirm

# Scope-lock: only act when the foreground app/window matches this substring.
#   Windows -> window title      (Notepad, nCara)
#   macOS   -> frontmost app name (Google Chrome, Safari, Notes, TextEdit)
CU_ALLOWED_WINDOW=Notepad

# Stop after this many agent steps no matter what.
CU_MAX_STEPS=40

# Max width (px) of the screenshot sent to the model. Coordinates are scaled back to real
# pixels before clicking. Keep <= ~1280 to avoid silent server-side downscaling + click drift.
CU_MAX_WIDTH=1280

# Keep the full image for only the last N screenshots; older ones are pruned to text to cap tokens.
CU_KEEP_IMAGES=3

# adaptive | off   (adaptive thinking helps planning but costs more per step)
CU_THINKING=adaptive
